/* --- Global Styles --- */
App {
    background: $surface;
    color: $text;
}

/* Ensure all modal overlay screens center their inner container */
ModalScreen {
    align: center middle;
}

/* --- Shared Screen Backgrounds (The Hashes) --- */
LoginScreen,
RegisterScreen,
PolicyScreen,
ChangePasswordScreen,
EditProfileScreen,
StaffConfirmScreen,
DirectorySelectScreen,
DatabaseLockModal {
    align: center middle;
    hatch: right $secondary 20%;
    background: $surface;
}

/* --- Content Containers --- */

/* Small centered box (Login, Change Password) */
.login-container {
    width: 60;
    height: auto;
    border: heavy $primary;
    background: $boost;
    padding: 2;
    align: center middle;
}

/* Medium/Large Form Box (Registration) */
.form-container {
    width: 80;
    max-width: 120;
    height: auto;
    max-height: 90%;
    border: heavy $primary;
    background: $surface;
    padding: 1 2;
    align: center top;
}

/* Large Splash Dialog (Policies, Edit Profile, Staff Confirm, Modals) */
.splash-container {
    width: 90%;
    height: 90%;
    max-height: 90%;
    background: $surface;
    border: heavy $primary;
    padding: 2;
}

/* Inner content box for Splash Dialogs */
.splash-content {
    height: 1fr; /* Takes up remaining vertical space */
    border: solid $secondary;
    background: $boost;
    padding: 1;
    margin: 1 0;
}

/* Default Directory Tree */
DirectoryTree {
    height: 20;
    border: solid $secondary;
    margin: 1 0;
    background: $boost;
}

/* --- Buttons --- */
Button {
    width: auto;
    min-width: 20;
    height: auto;
    content-align: center middle;
    padding: 0 2;
    margin: 1 1 1 0;
    background: $primary;
    color: $text;
    border: tall $primary;
}

/* Force main action buttons to be full width */
.login-container > Button,
.form-container > Button {
    width: 100%;
}

#read_tos, #read_coc {
    background: $surface;
    border: tall $primary;
    color: $text;
    width: auto;
}

Button.success {
    background: $success;
    color: black;
}

Button.error {
    background: $error;
    color: white;
}

/* --- Filters --- */
.filter-row {
    height: auto;
    margin: 1 0;
    align-vertical: middle;
}

.search-row {
    height: auto;
    margin: 1 0;
    align-vertical: middle;
}

.search-row Input {
    width: 1fr;
}

Checkbox {
    width: auto;
    margin-right: 2;
}

/* --- Text & Misc --- */
.logo-art {
    width: 100%;
    text-align: center;
    color: $secondary;
    margin: 1 0 1 0;
    text-style: dim;
}

/* Login screen header — two stacked lines with no gap between them */
.login-hackspace-name {
    text-align: center;
    text-style: bold;
    color: $secondary;
    width: 100%;
}

.login-app-name {
    text-align: center;
    color: $text-muted;
    width: 100%;
    margin-bottom: 1;
}

.title {
    text-align: center;
    text-style: bold;
    color: $secondary;
    margin-bottom: 2;
    width: 100%;
}

.subtitle {
    text-style: bold;
    margin-top: 1;
    color: $text-muted;
}

.form-subsection {
    height: auto;
    margin-top: 1;
    margin-bottom: 1;
    border: solid $secondary;
    padding: 1;
    background: $boost;
}

.error {
    color: $error;
    text-align: center;
}

Label {
    margin-top: 1;
}

/* Title and login labels sit at the top of containers — suppress the extra margin. */
.title {
    margin-top: 0;
}

.login-hackspace-name {
    margin-top: 0;
}

Input {
    margin: 1;
    color: $text;
}

Select {
    margin: 1 0;
}

Collapsible {
    margin-top: 1;
}

.scrollable {
    overflow-y: scroll;
    height: 100%;
}

.agreement-row {
    height: auto;
    align-vertical: middle;
    margin-bottom: 1;
}

/* --- Warning Banners --- */
.warning-banner {
    width: 100%;
    background: $error;
    color: white;
    text-align: center;
    text-style: bold;
    padding: 1;
    margin-bottom: 1;
    border-bottom: heavy white;
}

.hidden {
    display: none;
}

/* --- Directory Select Specifics --- */

DirectorySelectScreen .splash-container {
    layout: vertical;
}

/* Ensure the directory tree takes available space but leaves room for buttons */
DirectorySelectScreen DirectoryTree {
    height: 1fr;
    min-height: 10;
    margin-bottom: 2;
}

/* Ensure filter row (buttons) stays at bottom */
DirectorySelectScreen .filter-row {
    height: auto;
    dock: bottom;
}

/* --- Footer Version Label --- */
.version-footer {
    width: auto;
    dock: left;
    margin-left: 1;
    color: $text-muted;
}

.footer-container {
    height: auto;
    dock: bottom;
}

/* --- Login Screen Section Divider --- */
.login-section-label {
    width: 100%;
    text-align: center;
    color: $text-muted;
    margin-top: 1;
    border-top: solid $secondary 30%;
}

/* --- Tabs --- */
Tab {
    padding: 0 3;
    border-right: solid $secondary 40%;
}

Tab.-active {
    border-right: solid $secondary 40%;
}
